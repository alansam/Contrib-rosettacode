#!/usr/bin/env nr
/* NetRexx */
options replace format comments java symbols nobinary
-- . ... 1 ... ... 2 ... ... 3 ... ... 4 ... ... 5 ... ... 6 ... ... 7 ... ... 8

filenames = [ 2, "RFileSize01.nrx", "/usr/share/dict/words" ]

say
loop fn = 1 to filenames[0]
  filesize = Rexx java.io.File(filenames[fn]).length
  say '-'.copies(30) ':' '-'.copies(9)
  say filenames[fn].right(30) ':' filesize.right(9)
end fn
say

return

